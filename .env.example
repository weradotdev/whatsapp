# WhatsApp service (pm2 start ecosystem.config.cjs). Uses APP_URL for callbacks; defaults: PORT 3000, APP_URL http://localhost:8000
# WHATSAPP_BAILEYS_URL=   # Laravel calls this (default: http://localhost:3000)
# WHATSAPP_SERVICE_PORT=  # Optional (default: 3000)
# WHATSAPP_CALLBACK_TOKEN= # Optional: token for Baileys→Laravel callbacks
